    Learning is fun and exciting.
    """
    
    print("\n" + "="*70)
    print("TRAINING CORPUS:")
    print("="*70)
    print(training_text)
    
    # preprocessing
    print("\n" + "="*70)
    print("STEP 1: PREPROCESSING")
    print("="*70)
    words = clean_and_tokenize(training_text)
    print(f"Total words after cleaning: {len(words)}")
    print(f"Sample words: {words[:20]}...")
    
    # generate unigrams (just for analysis)
    print("\n" + "="*70)
    print("STEP 2: UNIGRAM ANALYSIS")
    print("="*70)
    unigram_counts = Counter(words)
    print("Most common unigrams (top 10):")
    for word, count in unigram_counts.most_common(10):
        print(f"  {word:<15} : {count} times")
    
    # bigram model
    print("\n" + "="*70)
    print("STEP 3: BIGRAM MODEL")
    print("="*70)
    bigram_model = NGramModel(n=2)
    bigram_model.train(words)
    
    # show some bigram examples
    print("\nSample bigram probabilities:")
    sample_contexts = [['learning'], ['machine'], ['language'], ['python']]
    for ctx in sample_contexts:
        probs = bigram_model.get_probabilities(ctx)
        if probs:
            print(f"\nContext: '{ctx[0]}'")
            for word, prob in list(probs.items())[:3]:
                print(f"  {word} -> {prob:.2%}")
    
    # trigram model
    print("\n" + "="*70)
    print("STEP 4: TRIGRAM MODEL")
    print("="*70)
    trigram_model = NGramModel(n=3)
    trigram_model.train(words)
    
    print("\nSample trigram probabilities:")
    sample_trigrams = [['natural', 'language'], ['machine', 'learning'], ['deep', 'learning']]
    for ctx in sample_trigrams:
        probs = trigram_model.get_probabilities(ctx)
        if probs:
            print(f"\nContext: '{ctx[0]} {ctx[1]}'")
            for word, prob in list(probs.items())[:3]:
                print(f"  {word} -> {prob:.2%}")
    
    # prediction demo
    print("\n" + "="*70)
    print("STEP 5: NEXT WORD PREDICTION")
    print("="*70)
    
    test_inputs = [
        (["natural", "language"], 3),
        (["machine", "learning"], 3),
        (["i", "love"], 2),
        (["the", "quick"], 3),
        (["deep", "learning"], 3),
        (["learning", "is"], 2)
    ]
    
    for test_input, model_type in test_inputs:
        print(f"\nInput: {' '.join(test_input)}")
        
        if model_type == 3:
            # try trigram first
            pred, prob = trigram_model.predict_next(test_input)
            if pred:
                print(f"Trigram prediction: '{pred}' (confidence: {prob:.2%})")
                trigram_model.show_top_predictions(test_input, top_k=3)
            else:
                # fallback to bigram
                print("Trigram not found, trying bigram...")
                pred, prob = bigram_model.predict_next([test_input[-1]])
                if pred:
                    print(f"Bigram prediction: '{pred}' (confidence: {prob:.2%})")
        else:
            # use bigram
            pred, prob = bigram_model.predict_next([test_input[-1]])
            if pred:
                print(f"Bigram prediction: '{pred}' (confidence: {prob:.2%})")
                bigram_model.show_top_predictions([test_input[-1]], top_k=3)
    
