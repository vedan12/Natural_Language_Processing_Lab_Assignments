def clean_and_tokenize(txt):
    """basic cleaning and tokenization"""
    txt = txt.lower()
    # keeping only alphabets and spaces
    txt = re.sub(r'[^a-zA-Z\s]', '', txt)
    words = word_tokenize(txt)
    return words

class NGramModel:
    """simple n-gram model for next word prediction"""
    
    def __init__(self, n=2):
        self.n = n  # n-gram order (2=bigram, 3=trigram)
        self.ngrams = defaultdict(Counter)  # stores counts of n-grams
        self.vocab = set()  # vocabulary
        
    def train(self, words):
        """train the model on list of words"""
        print(f"\nTraining {self.n}-gram model...")
        
        for i in range(len(words) - self.n + 1):
            # get context (first n-1 words) and next word (last word)
            context = tuple(words[i:i+self.n-1])
            next_word = words[i+self.n-1]
            
            # store counts
            self.ngrams[context][next_word] += 1
            self.vocab.add(next_word)
        
        print(f"Found {len(self.ngrams)} unique contexts")
        print(f"Vocabulary size: {len(self.vocab)}")
    
    def get_probabilities(self, context):
        """get probability distribution for given context"""
        context = tuple(context)
        
        if context not in self.ngrams:
            return None
        
        total = sum(self.ngrams[context].values())
        probs = {}
        for word, count in self.ngrams[context].items():
            probs[word] = count / total
        
        return probs
    
    def predict_next(self, context_words):
        """predict most probable next word"""
        # take last n-1 words as context
        if len(context_words) < self.n - 1:
            return None, "Not enough words for context"
        
        context = tuple(context_words[-(self.n-1):])
        
        if context not in self.ngrams:
            return None, "Context not found in training data"
        
        # find word with highest probability
        probs = self.get_probabilities(context)
        if probs:
            best_word = max(probs, key=probs.get)
            return best_word, probs[best_word]
        
        return None, "No prediction available"
    
    def show_top_predictions(self, context_words, top_k=5):
        """show top k predictions for given context"""
        if len(context_words) < self.n - 1:
            print(f"Need at least {self.n-1} words, got {len(context_words)}")
            return
        
        context = tuple(context_words[-(self.n-1):])
        
        if context not in self.ngrams:
            print(f"Context '{' '.join(context)}' not found in training")
            return
        
        probs = self.get_probabilities(context)
        if probs:
            sorted_words = sorted(probs.items(), key=lambda x: x[1], reverse=True)[:top_k]
            print(f"\nTop {top_k} predictions for context '{' '.join(context)}':")
            print("-"*50)
            for word, prob in sorted_words:
                print(f"  {word:<15} : {prob:.2%}")
            return sorted_words

# main execution
if __name__ == "__main__":
    
    # training corpus - using sentences that show patterns
    training_text = """
    Natural language processing is a fascinating field. 
    Machine learning is a subset of artificial intelligence. 
    Deep learning is a subset of machine learning. 
    Natural language processing uses machine learning techniques. 
    Students learn natural language processing in college. 
    I love programming in Python. 
    Python is great for machine learning. 
    Machine learning models need training data. 
