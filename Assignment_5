def evaluate_challenges():
    """evaluate challenges in building context-aware chatbots"""
    print("\n" + "="*70)
    print("CHALLENGES IN BUILDING CONTEXT-AWARE CHATBOTS")
    print("="*70)
    
    challenges = {
        "1. Syntactic Ambiguity": """
   Problem: Same sentence structure can have multiple meanings
   Example: 'I saw her duck'
   Impact: Chatbot may misinterpret user intent
   Solution: POS tagging + dependency parsing""",
        
        "2. Lexical Ambiguity": """
   Problem: Words with multiple meanings
   Example: 'book' (noun) vs 'book' (verb)
   Impact: Wrong intent detection
   Solution: Word Sense Disambiguation (WSD)""",
        
        "3. Context Tracking": """
   Problem: Maintaining conversation history across turns
   Example: User: 'Weather in Pune?' Bot: '30°C'
          User: 'What about tomorrow?'
   Impact: Without context, bot doesn't know topic
   Solution: Dialogue state tracking + memory mechanisms""",
        
        "4. Anaphora Resolution": """
   Problem: Understanding pronouns like 'he', 'she', 'it', 'they'
   Example: 'John bought a car. It is red.'
   Impact: Bot doesn't know what 'it' refers to
   Solution: Coreference resolution models""",
        
        "5. Data Scarcity": """
   Problem: Need large labeled datasets for training
   Impact: Poor performance for rare intents
   Solution: Transfer learning, data augmentation""",
        
        "6. Real-time Processing": """
   Problem: Need fast responses while maintaining accuracy
   Impact: Trade-off between speed and quality
   Solution: Optimized models, caching strategies"""
    }
    
    for challenge, details in challenges.items():
        print(f"\n{challenge}:")
        print(details)
    
    return challenges

