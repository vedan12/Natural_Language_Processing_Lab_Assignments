    """analyze the classic 'duck' ambiguity example"""
    print("\n" + "="*70)
    print("CASE STUDY: SYNTACTIC AMBIGUITY")
    print("="*70)
    
    ambiguous_sentence = "I saw her duck"
    
    print(f"\nClassic Ambiguous Sentence: '{ambiguous_sentence}'")
    print("\nPossible interpretations:")
    print("1. I saw her duck (the bird) → duck as NOUN")
    print("2. I saw her duck (to lower her head) → duck as VERB")
    
    # analyze with POS tagging
    analyze_syntactic_ambiguity(ambiguous_sentence)
    
    return ambiguous_sentence

