def analyze_syntactic_ambiguity(sentence):
    """analyze syntactic ambiguity in a sentence"""
    words = word_tokenize(sentence)
    pos_tags = pos_tag(words)
    
    print(f"\nAnalyzing: '{sentence}'")
    print("-"*50)
    print("POS Tagging:")
    for word, tag in pos_tags:
        print(f"  {word}: {tag}")
    
    return pos_tags

