def simple_intent_detection_demo():
    """simple demonstration of intent detection with ambiguity handling"""
    print("\n" + "="*70)
    print("INTENT DETECTION DEMONSTRATION")
    print("="*70)
    
    # sample training data with ambiguous examples
    training_data = [
        ("book a flight", "booking"),
        ("read a book", "reading"),
        ("I want to book tickets", "booking"),
        ("this book is interesting", "reading"),
        ("duck under the table", "action"),
        ("feed the duck", "animal"),
        ("I saw her duck", "ambiguous"),
        ("weather today", "weather"),
        ("what's the temperature", "weather")
    ]
    
    print("\nExample: Handling ambiguous 'duck'")
    print("-"*40)
    
    ambiguous_queries = [
        "I saw her duck",
        "The duck is swimming",
        "She ducked under the table"
    ]
    
    for query in ambiguous_queries:
        print(f"\nQuery: '{query}'")
        words = word_tokenize(query)
        tags = pos_tag(words)
        
        # simple rule-based disambiguation
        for word, tag in tags:
            if word == 'duck' and tag == 'NN':
                print(f"  → 'duck' is NOUN (animal/bird)")
            elif word == 'duck' and tag in ['VB', 'VBD', 'VBG']:
                print(f"  → 'duck' is VERB (lower head/avoid)")
        
        print(f"  POS Tags: {tags}")
    
    return training_data

