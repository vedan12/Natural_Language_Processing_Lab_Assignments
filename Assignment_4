def clean_and_tokenize(txt):
    """simple cleaning and tokenization"""
    txt = txt.lower()
    txt = re.sub(r'[^a-zA-Z\s]', '', txt)
    words = word_tokenize(txt)
    return words

def create_one_hot(word_idx, vocab_size):
    """create one-hot encoded vector for a word"""
    one_hot = np.zeros(vocab_size)
    one_hot[word_idx] = 1
    return one_hot

class SimpleWord2Vec:
    """simple implementation of Skip-gram word2vec"""
    
    def __init__(self, vocab_size, embedding_dim=50):
        self.vocab_size = vocab_size
        self.embedding_dim = embedding_dim
        
        # initialize weights randomly
        self.w1 = np.random.randn(vocab_size, embedding_dim) / np.sqrt(embedding_dim)
        self.w2 = np.random.randn(embedding_dim, vocab_size) / np.sqrt(embedding_dim)
        
    def forward(self, input_word):
        """forward pass to get predictions"""
        h = np.dot(input_word, self.w1)  # hidden layer
        u = np.dot(h, self.w2)  # output layer
        # softmax activation
        exp_u = np.exp(u - np.max(u))
        y_pred = exp_u / np.sum(exp_u)
        return y_pred, h
    
    def backward(self, input_word, target, y_pred, h, learning_rate=0.01):
        """backward pass to update weights"""
        # calculate error
        error = y_pred - target
        
        # update w2
        grad_w2 = np.outer(h, error)
        self.w2 -= learning_rate * grad_w2
        
        # update w1
        grad_w1 = np.outer(input_word, np.dot(error, self.w2.T))
        self.w1 -= learning_rate * grad_w1
        
    def train(self, training_pairs, epochs=100, learning_rate=0.01, verbose=True):
        """train the model on skip-gram pairs"""
        losses = []
        
        for epoch in range(epochs):
            total_loss = 0
            
            for target_word, context_word in training_pairs:
                # forward pass
                y_pred, h = self.forward(target_word)
                total_loss += -np.log(y_pred[np.argmax(context_word)] + 1e-8)
                
                # backward pass
                self.backward(target_word, context_word, y_pred, h, learning_rate)
            
            avg_loss = total_loss / len(training_pairs)
            losses.append(avg_loss)
            
            if verbose and (epoch + 1) % 20 == 0:
                print(f"Epoch {epoch+1}/{epochs}, Loss: {avg_loss:.4f}")
        
        return losses
    
    def get_embedding(self, word_idx):
        """get embedding vector for a word"""
        return self.w1[word_idx]
    
    def cosine_similarity(self, vec1, vec2):
        """compute cosine similarity between two vectors"""
        if np.linalg.norm(vec1) == 0 or np.linalg.norm(vec2) == 0:
            return 0
        return np.dot(vec1, vec2) / (np.linalg.norm(vec1) * np.linalg.norm(vec2))
    
    def find_similar_words(self, word_idx, word_list, idx_to_word, top_k=5):
        """find most similar words using cosine similarity"""
        word_vec = self.get_embedding(word_idx)
        similarities = []
        
        for idx in range(self.vocab_size):
            if idx != word_idx:
                sim = self.cosine_similarity(word_vec, self.get_embedding(idx))
                similarities.append((idx, sim))
        
        similarities.sort(key=lambda x: x[1], reverse=True)
        similar_words = []
        for idx, sim in similarities[:top_k]:
            similar_words.append((idx_to_word[idx], sim))
        
        return similar_words

def create_skipgram_pairs(words, window_size=2, word_to_idx=None):
    """create training pairs for skip-gram model"""
    pairs = []
    
    for i, target_word in enumerate(words):
        # define context window
        start = max(0, i - window_size)
        end = min(len(words), i + window_size + 1)
        
        context_words = [words[j] for j in range(start, end) if j != i]
        
        for context in context_words:
            pairs.append((target_word, context))
    
    return pairs

