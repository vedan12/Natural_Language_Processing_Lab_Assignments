def preprocess_text(txt):
    """clean and preprocess text"""
    txt = txt.lower()
    txt = re.sub(r'[^a-zA-Z\s]', '', txt)
    words = word_tokenize(txt)
    # remove stopwords
    stop_words = set(stopwords.words('english'))
    words = [w for w in words if w not in stop_words]
    return words

def get_sentence_embedding(words, model, embedding_dim=100):
    """convert sentence to vector by averaging word embeddings"""
    word_vectors = []
    for word in words:
        if word in model:
            word_vectors.append(model[word])
    
    if len(word_vectors) == 0:
        return np.zeros(embedding_dim)
    
    return np.mean(word_vectors, axis=0)

def load_embeddings():
    """load pre-trained word2vec model"""
    print("Loading pre-trained Word2Vec model (this may take a moment)...")
    # using glove-twitter-25 for faster loading, or you can use word2vec-google-news-300
    model = api.load('glove-twitter-25')
    print("Model loaded successfully!")
    return model

