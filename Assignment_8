    print("\n" + "="*70)
    print("STEP 1: DATASET OVERVIEW")
    print("="*70)
    print(f"Total tickets: {len(tickets)}")
    print(f"Categories: {set(labels)}")
    print("\nSample tickets:")
    for i in range(5):
        print(f"  {i+1}. {texts[i][:60]}... -> {labels[i]}")
    
    # step 2: preprocess all tickets
    print("\n" + "="*70)
    print("STEP 2: TEXT PREPROCESSING")
    print("="*70)
    
    processed_tickets = [preprocess_text(txt) for txt in texts]
    print("Sample preprocessing:")
    print(f"  Original: {texts[0]}")
    print(f"  Processed: {processed_tickets[0]}")
    
    # step 3: load word embeddings
    print("\n" + "="*70)
    print("STEP 3: LOADING WORD EMBEDDINGS")
    print("="*70)
    
    word2vec_model = load_embeddings()
