        ("Refund not processed even after 7 days", "billing"),
        ("Invoice not generated after payment", "billing"),
        ("Want to cancel subscription but still charged", "billing"),
        ("Payment method update failed", "billing"),
        
        # Technical Issues
        ("Application crashes when I open the dashboard", "technical"),
        ("Error 404 when accessing my profile page", "technical"),
        ("App freezes during video upload", "technical"),
        ("Loading takes forever, page stuck", "technical"),
        ("Feature not working after latest update", "technical"),
        ("Unable to upload files, shows error", "technical"),
        
        # Product Inquiry
