import numpy as np
import gensim.downloader as api
from sklearn.metrics.pairwise import cosine_similarity
import re
import time

# --- STEP 1: LOAD PRE-TRAINED EMBEDDINGS ---
def load_model():
    print("Loading pre-trained Word2Vec/GloVe model...")
    # Using 'glove-twitter-25' for faster execution in lab environment
    model = api.load('glove-twitter-25') 
    print("Model loaded successfully!")
    return model

# --- STEP 2: PREPROCESSING FUNCTION ---
def preprocess(text):
    text = text.lower()
    text = re.sub(r'[^a-z\s]', '', text)
    return text.split()

# --- STEP 3: SENTENCE TO VECTOR (AVERAGE EMBEDDING) ---
def get_sentence_vector(words, model):
    word_vectors = [model[word] for word in words if word in model]
    if not word_vectors:
        return np.zeros(model.vector_size)
    return np.mean(word_vectors, axis=0)

# --- MAIN EXECUTION ---
if __name__ == "__main__":
    # Load model once
    word2vec_model = load_model()
    
    # Dataset of sentences (FAQ)
    faq_dataset = [
        "How do I reset my account password?",
        "What are the best laptops for software development?",
        "The application is crashing on the startup screen.",
        "I want to upgrade my subscription plan.",
        "How to track my order delivery status?"
    ]
    
    print("\n" + "="*80)
    print("STEP 1: DATASET INDEXING (Generating Sentence Embeddings)")
    print("="*80)
    dataset_vectors = []
    for i, sentence in enumerate(faq_dataset):
        processed = preprocess(sentence)
        vector = get_sentence_vector(processed, word2vec_model)
        dataset_vectors.append(vector)
        print(f"Index {i}: {sentence[:50]}... -> Vector Size: {vector.shape}")

    # --- STEP 2: REAL-TIME SEMANTIC SEARCH EVALUATION ---
    queries = [
        "forgot login credentials",      # Semantic match to password
        "coding computers",              # Semantic match to laptops
        "software is hanging",           # Semantic match to crashing
    ]

    print("\n" + "="*80)
    print("STEP 2: REAL-TIME SEMANTIC SEARCH EVALUATION")
    print("="*80)
    print(f"{'User Query':<30} | {'Top Semantic Match':<40} | {'Score'}")
    print("-" * 80)

    for q_text in queries:
        q_processed = preprocess(q_text)
        q_vector = get_sentence_vector(q_processed, word2vec_model).reshape(1, -1)
        
        # Calculate similarity against all dataset vectors
        sims = [cosine_similarity(q_vector, v.reshape(1, -1))[0][0] for v in dataset_vectors]
        best_idx = np.argmax(sims)
        
        print(f"{q_text:<30} | {faq_dataset[best_idx][0:38]:<40} | {sims[best_idx]:.4f}")

    # --- STEP 3: WORD VECTOR SIMILARITY ANALYSIS ---
    print("\n" + "="*80)
    print("STEP 3: WORD VECTOR SIMILARITY ANALYSIS (PROVING THEORY)")
    print("="*80)
    word_pairs = [('laptop', 'computer'), ('password', 'login'), ('crash', 'freeze')]
    for w1, w2 in word_pairs:
        if w1 in word2vec_model and w2 in word2vec_model:
            sim = word2vec_model.similarity(w1, w2)
            print(f"Similarity between '{w1}' and '{w2}': {sim:.4f}")
    
    print("\n" + "="*80)
    print("ANALYSIS SUMMARY")
    print("="*80)
    print("The results demonstrate that word embeddings capture contextual meaning.")
    print("Synonyms (like 'computer' and 'laptop') show high similarity scores,")
    print("allowing the search system to work without exact keyword matching.")
    print("="*80)
